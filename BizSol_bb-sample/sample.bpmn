    <bpmn:sequenceFlow id="Flow_0ogak95" sourceRef="Activity_0xl1zbt" targetRef="Event_0mk5lgn" />
    <bpmn:endEvent id="bb-sample" name="got a 👋">
      <bpmn:incoming>Flow_1g5kuh1</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1g5kuh1" sourceRef="Event_0mk5lgn" targetRef="bb-sample" />
    <bpmn:intermediateCatchEvent id="Event_0mk5lgn" name="wait for 3 sec">
      <bpmn:incoming>Flow_0ogak95</bpmn:incoming>
      <bpmn:outgoing>Flow_1g5kuh1</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_0y3nt6u">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT3S</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
  </bpmn:process>
