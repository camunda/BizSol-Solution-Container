  <bpmn:process id="sample" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="needs a 👋">
      <bpmn:outgoing>Flow_1lynztl</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Activity_0xl1zbt" name="Hello World!">
      <bpmn:incoming>Flow_1lynztl</bpmn:incoming>
      <bpmn:outgoing>Flow_0ogak95</bpmn:outgoing>
    </bpmn:task>
